# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Replace with your PostgreSQL connection string
# For Render: Use the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/release_checklist?schema=public"

# CORS Configuration
# Comma-separated origins allowed (supports multiple for local + production)
CORS_ORIGIN=http://localhost:5173,https://cactro-release-check.vercel.app
