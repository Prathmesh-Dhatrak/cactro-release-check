# Auto-normalize line endings for all text files
* text=auto

# Force LF for source files (consistent across OS)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.prisma text eol=lf

# Keep lockfiles as-is
pnpm-lock.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
